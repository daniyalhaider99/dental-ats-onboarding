{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "personal_details",
    "job_preferences",
    "employment",
    "educations",
    "work_experiences",
    "languages",
    "skills",
    "availability",
    "summary",
    "low_confidence_fields"
  ],
  "properties": {
    "personal_details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_name", "last_name", "email", "phone", "city", "country"],
      "properties": {
        "first_name": { "type": ["string", "null"] },
        "last_name": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"] },
        "phone": { "type": ["string", "null"] },
        "city": { "type": ["string", "null"] },
        "country": { "type": ["string", "null"] }
      }
    },
    "job_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_job_title", "suggested_job_function"],
      "properties": {
        "current_job_title": { "type": ["string", "null"] },
        "suggested_job_function": {
          "type": ["string", "null"],
          "enum": [
            "general_dentist",
            "specialist",
            "dental_hygienist",
            "prevention_assistant",
            "paro_prevention_assistant",
            "dental_assistant",
            "orthodontic_assistant",
            "front_office",
            "practice_manager",
            "dental_technician",
            null
          ]
        }
      }
    },
    "employment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["big_status", "big_number", "years_of_experience"],
      "properties": {
        "big_status": {
          "type": ["string", "null"],
          "enum": ["registered", "in_progress", "under_supervision", "not_applicable", null]
        },
        "big_number": { "type": ["string", "null"] },
        "years_of_experience": { "type": ["integer", "null"] }
      }
    },
    "educations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["institution", "study", "city_and_country", "level", "start_date", "end_date"],
        "properties": {
          "institution": { "type": ["string", "null"] },
          "study": { "type": ["string", "null"] },
          "city_and_country": { "type": ["string", "null"] },
          "level": {
            "type": ["string", "null"],
            "enum": ["mbo", "hbo", "bachelor", "master", "doctor", "course", null]
          },
          "start_date": { "type": ["string", "null"] },
          "end_date": { "type": ["string", "null"] }
        }
      }
    },
    "work_experiences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["job_title", "company_name", "responsibilities", "start_date", "end_date", "current_job"],
        "properties": {
          "job_title": { "type": ["string", "null"] },
          "company_name": { "type": ["string", "null"] },
          "responsibilities": { "type": ["string", "null"] },
          "start_date": { "type": ["string", "null"] },
          "end_date": { "type": ["string", "null"] },
          "current_job": { "type": ["boolean", "null"] }
        }
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "proficiency"],
        "properties": {
          "name": { "type": ["string", "null"] },
          "proficiency": {
            "type": ["string", "null"],
            "enum": ["a1", "a2", "b1", "b2", "c1", "c2", "native", null]
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "availability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available_from", "notice_period"],
      "properties": {
        "available_from": { "type": ["string", "null"] },
        "notice_period": { "type": ["string", "null"] }
      }
    },
    "summary": { "type": ["string", "null"] },
    "low_confidence_fields": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
