<div class="mx-auto max-w-2xl px-4 py-12">
  <ol class="mb-8 flex items-center gap-3 text-sm">
    <li class="flex items-center gap-2 font-medium text-slate-900">
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-slate-900 text-xs text-white">1</span>
      Upload CV
    </li>
    <li aria-hidden="true" class="h-px w-8 bg-slate-300"></li>
    <li class="flex items-center gap-2 text-slate-400">
      <span class="flex h-6 w-6 items-center justify-center rounded-full border border-slate-300 text-xs">2</span>
      Review profile
    </li>
  </ol>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="text-xl font-semibold text-slate-900">Upload your CV</h1>
    <p class="mt-2 text-sm text-slate-600">
      We will automatically fill in as much of your candidate profile as possible.
      You can review and edit everything before saving.
    </p>

    <%= form_with model: @upload_form,
                  scope: :onboarding_upload_form,
                  url: onboarding_cv_upload_path,
                  class: "mt-6 space-y-5" do |form| %>
      <% if @upload_form.errors.any? %>
        <div class="rounded-md border border-red-200 bg-red-50 p-4" role="alert">
          <ul class="list-inside list-disc space-y-1 text-sm text-red-800">
            <% @upload_form.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div data-controller="file-upload"
           data-file-upload-max-size-value="<%= CvParsing::Settings.max_file_size %>"
           class="rounded-lg border-2 border-dashed border-slate-300 p-8 text-center transition-colors"
           data-file-upload-target="dropzone"
           data-action="dragover->file-upload#dragOver dragleave->file-upload#dragLeave drop->file-upload#drop">
        <%= form.file_field :file,
                            accept: ".pdf,.doc,.docx",
                            class: "block w-full text-sm text-slate-600 file:mr-4 file:rounded-md file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-slate-700",
                            data: { file_upload_target: "input", action: "change->file-upload#fileSelected" } %>

        <p class="mt-3 text-xs text-slate-500" data-file-upload-target="hint">
          PDF, DOC or DOCX, up to <%= CvParsing::Settings.max_file_size_megabytes %> MB.
        </p>
      </div>

      <label class="flex items-start gap-3 text-sm text-slate-700">
        <%= form.check_box :consent, class: "mt-0.5 h-4 w-4 rounded border-slate-300" %>
        <span>
          I agree that my CV and profile information may be processed to create and
          improve my candidate profile.
        </span>
      </label>

      <div class="flex items-center gap-3">
        <%= form.submit "Analyze CV",
                        class: "rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
        <%= link_to "Continue manually", root_path,
                    class: "text-sm font-medium text-slate-600 underline hover:text-slate-900" %>
      </div>
    <% end %>
  </div>
</div>
