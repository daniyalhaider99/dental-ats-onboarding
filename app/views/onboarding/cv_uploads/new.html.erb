<div class="mx-auto max-w-2xl py-10">
  <div class="mb-8 flex items-center gap-3">
    <%= onboarding_step_indicator(1) %>
  </div>

  <div class="app-card overflow-hidden">
    <div class="border-b border-slate-100 bg-gradient-to-br from-brand-50/80 to-white px-6 py-7">
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Upload your CV</h1>
      <p class="mt-2 max-w-lg text-sm leading-relaxed text-slate-600">
        We'll automatically fill in as much of your candidate profile as possible.
        You can review and edit everything before saving.
      </p>
    </div>

    <div class="p-6">
      <%= form_with model: @upload_form,
                    scope: :onboarding_upload_form,
                    url: onboarding_cv_upload_path,
                    class: "space-y-5" do |form| %>
        <% if @upload_form.errors.any? %>
          <div class="flex gap-3 rounded-xl border border-red-200 bg-red-50 p-4" role="alert">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle><path d="M12 8v4M12 16h.01"></path>
            </svg>
            <ul class="space-y-1 text-sm text-red-800">
              <% @upload_form.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div data-controller="file-upload"
             data-file-upload-max-size-value="<%= CvParsing::Settings.max_file_size %>"
             class="group relative rounded-2xl border-2 border-dashed border-slate-300 bg-slate-50/50 px-6 py-10 text-center transition-colors hover:border-brand-400 hover:bg-brand-50/40"
             data-file-upload-target="dropzone"
             data-action="dragover->file-upload#dragOver dragleave->file-upload#dragLeave drop->file-upload#drop">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-brand-100 text-brand-600">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 16V4M7 9l5-5 5 5"></path><path d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2"></path>
            </svg>
          </div>

          <p class="text-sm font-medium text-slate-700">
            Drag &amp; drop your CV here, or
            <span class="font-semibold text-brand-700">browse</span>
          </p>

          <%= form.file_field :file,
                              accept: ".pdf,.doc,.docx",
                              class: "mx-auto mt-4 block w-full max-w-xs text-sm text-slate-600 file:mr-3 file:rounded-lg file:border-0 file:bg-brand-600 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-brand-700",
                              data: { file_upload_target: "input", action: "change->file-upload#fileSelected" } %>

          <p class="mt-4 text-xs text-slate-500" data-file-upload-target="hint">
            PDF, DOC or DOCX · up to <%= CvParsing::Settings.max_file_size_megabytes %> MB
          </p>
        </div>

        <label class="flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50/50 p-4 text-sm text-slate-700">
          <%= form.check_box :consent, class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>
          <span>
            I agree that my CV and profile information may be processed to create and
            improve my candidate profile.
          </span>
        </label>

        <div class="flex items-center justify-between pt-1">
          <%= form.submit "Analyze CV", class: "btn-primary" %>
          <%= link_to "Back", root_path, class: "btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>

  <p class="mt-6 flex items-center justify-center gap-1.5 text-xs text-slate-400">
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0110 0v4"></path>
    </svg>
    Your CV is stored privately and only shared with the recruitment team.
  </p>
</div>
