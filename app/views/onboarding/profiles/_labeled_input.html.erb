<% provenance = local_assigns[:provenance] %>
<% hint = local_assigns[:hint] %>
<% placeholder = local_assigns[:placeholder] %>
<div class="space-y-1">
  <div class="flex items-center justify-between gap-2">
    <%= form.label field, local_assigns[:label], class: "field-label" %>
    <% if provenance %>
      <%= provenance_badge(provenance, field) %>
    <% end %>
  </div>
  <%= form.public_send(
        local_assigns.fetch(:as, :text_field),
        field,
        class: "form-input",
        placeholder: placeholder
      ) %>
  <% if hint %>
    <p class="text-xs text-slate-400"><%= hint %></p>
  <% end %>
</div>
