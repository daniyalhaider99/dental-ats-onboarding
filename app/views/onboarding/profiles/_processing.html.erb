<div class="app-card overflow-hidden" role="status" aria-live="polite">
  <div class="flex items-center gap-4 border-b border-slate-100 bg-gradient-to-br from-brand-50/80 to-white px-6 py-6">
    <span class="relative flex h-11 w-11 items-center justify-center">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400/40"></span>
      <span class="relative inline-flex h-11 w-11 items-center justify-center rounded-full bg-brand-600 text-white">
        <svg class="h-5 w-5 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-90" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
        </svg>
      </span>
    </span>
    <div>
      <p class="text-sm font-semibold text-slate-900">Analysing your CV…</p>
      <p class="text-xs text-slate-500">This usually takes a few seconds — the form will appear automatically.</p>
    </div>
  </div>

  <div class="space-y-5 p-6" aria-hidden="true">
    <% 3.times do %>
      <div class="space-y-3 rounded-xl border border-slate-100 p-4">
        <div class="h-3 w-1/3 animate-pulse rounded-full bg-slate-200"></div>
        <div class="grid grid-cols-2 gap-3">
          <div class="h-9 animate-pulse rounded-lg bg-slate-100"></div>
          <div class="h-9 animate-pulse rounded-lg bg-slate-100"></div>
        </div>
      </div>
    <% end %>
  </div>
</div>
