<div class="rounded-md border border-slate-200 p-4" data-nested-form-target="row"
     data-controller="current-job">
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <%= render "onboarding/profiles/labeled_input", form: wf, field: :job_title, label: "Job title" %>
    <%= render "onboarding/profiles/labeled_input", form: wf, field: :company_name, label: "Company name" %>
    <%= render "onboarding/profiles/labeled_input", form: wf, field: :start_date, label: "Start date (optional)", as: :date_field %>

    <div class="space-y-1" data-current-job-target="endDate">
      <%= wf.label :end_date, "End date (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= wf.date_field :end_date,
            class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
    </div>
  </div>

  <div class="mt-3">
    <%= wf.label :responsibilities, "Responsibilities (optional)", class: "block text-sm font-medium text-slate-700" %>
    <%= wf.text_area :responsibilities, rows: 2,
          class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
  </div>

  <label class="mt-3 flex items-center gap-2 text-sm text-slate-700">
    <%= wf.check_box :current_job, data: { action: "current-job#toggle", current_job_target: "checkbox" },
          class: "h-4 w-4 rounded border-slate-300" %>
    This is my current job
  </label>

  <%= wf.hidden_field :position %>
  <div class="mt-3 flex justify-end">
    <%= wf.hidden_field :_destroy, data: { nested_form_target: "destroy" } %>
    <button type="button" data-action="nested-form#remove"
            class="text-sm font-medium text-red-600 hover:text-red-700">
      Remove
    </button>
  </div>
</div>
