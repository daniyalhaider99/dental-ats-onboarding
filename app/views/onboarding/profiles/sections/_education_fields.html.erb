<div class="rounded-md border border-slate-200 p-4" data-nested-form-target="row">
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <%= render "onboarding/profiles/labeled_input", form: ef, field: :study, label: "Study / course" %>
    <%= render "onboarding/profiles/labeled_input", form: ef, field: :institution, label: "Institution (optional)" %>
    <%= render "onboarding/profiles/labeled_input", form: ef, field: :city_and_country, label: "City and country (optional)" %>

    <div class="space-y-1">
      <%= ef.label :level, "Level (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= ef.select :level, onboarding_education_levels, { include_blank: "Select…" },
            class: "form-input" %>
    </div>

    <%= render "onboarding/profiles/labeled_input", form: ef, field: :start_date, label: "Start date (optional)", as: :date_field %>
    <%= render "onboarding/profiles/labeled_input", form: ef, field: :end_date, label: "End date (optional)", as: :date_field %>
  </div>

  <%= ef.hidden_field :position %>
  <div class="mt-3 flex justify-end">
    <%= ef.hidden_field :_destroy, data: { nested_form_target: "destroy" } %>
    <button type="button" data-action="nested-form#remove"
            class="text-sm font-medium text-red-600 hover:text-red-700">
      Remove
    </button>
  </div>
</div>
