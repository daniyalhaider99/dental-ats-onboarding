<section class="section-card">
  <%= onboarding_section_header("Availability", :availability) %>

  <fieldset class="mt-4">
    <legend class="text-sm font-medium text-slate-700">Available working days</legend>
    <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
      <% onboarding_working_days.each do |day| %>
        <label class="choice-pill">
          <%= check_box_tag "candidate_profile[working_day_ids][]", day.id,
                            form.object.working_day_ids.include?(day.id),
                            id: "working_day_#{day.id}", class: "h-4 w-4 rounded border-slate-300" %>
          <%= day.name %>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <%= render "onboarding/profiles/labeled_input", form: form, field: :available_from, label: "Available from", as: :date_field %>
    <%= render "onboarding/profiles/labeled_input", form: form, field: :notice_period, label: "Notice period (optional)" %>
  </div>
</section>
