<section class="section-card"
         data-controller="nested-form"
         data-nested-form-association-value="work_experiences">
  <div class="flex items-center justify-between">
    <%= onboarding_section_header("Work experience", :work) %>
    <button type="button" data-action="nested-form#add" class="inline-flex items-center gap-1.5 rounded-lg border border-brand-200 bg-brand-50 px-3 py-1.5 text-sm font-medium text-brand-700 transition hover:bg-brand-100"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"></path></svg>Add work experience</button>
  </div>

  <template data-nested-form-target="template">
    <%= form.fields_for :work_experiences, WorkExperience.new, child_index: "NEW_RECORD" do |wf| %>
      <%= render "onboarding/profiles/sections/work_experience_fields", wf: wf %>
    <% end %>
  </template>

  <div data-nested-form-target="target" class="mt-4 space-y-4">
    <%= form.fields_for :work_experiences do |wf| %>
      <%= render "onboarding/profiles/sections/work_experience_fields", wf: wf %>
    <% end %>
  </div>
</section>
