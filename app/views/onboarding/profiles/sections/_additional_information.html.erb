<section class="section-card">
  <%= onboarding_section_header("Additional information", :additional) %>

  <div class="mt-4 space-y-4">
    <div class="space-y-1">
      <div class="flex items-center justify-between gap-2">
        <%= form.label :professional_summary, "Professional summary", class: "block text-sm font-medium text-slate-700" %>
        <%= provenance_badge(CandidateProfiles::FieldProvenance.new(form.object), :professional_summary) %>
      </div>
      <%= form.text_area :professional_summary, rows: 3,
            class: "form-input" %>
    </div>

    <div class="space-y-1">
      <%= form.label :motivation, "Motivation for employer (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_area :motivation, rows: 3,
            class: "form-input" %>
    </div>

    <div class="space-y-1">
      <%= form.label :internal_notes, "Internal notes (only you fill this in)", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_area :internal_notes, rows: 2,
            class: "form-input" %>
    </div>
  </div>
</section>
