<section class="section-card">
  <%= onboarding_section_header("Job preferences", :preferences) %>

  <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="space-y-1">
      <div class="flex items-center justify-between gap-2">
        <%= form.label :job_function_id, "Desired job function", class: "block text-sm font-medium text-slate-700" %>
        <%= provenance_badge(provenance, :job_function_id) %>
      </div>
      <select name="candidate_profile[job_function_id]" id="candidate_profile_job_function_id"
              data-conditional-fields-target="jobFunction"
              data-action="change->conditional-fields#jobFunctionChanged"
              class="form-input">
        <option value="">Select a function…</option>
        <% onboarding_job_functions.each do |fn| %>
          <option value="<%= fn.id %>"
                  data-requires-big="<%= fn.requires_big_registration %>"
                  data-revenue-relevant="<%= fn.revenue_relevant %>"
                  data-skill-group="<%= fn.skill_group_id %>"
                  <%= "selected" if form.object.job_function_id == fn.id %>>
            <%= fn.name %>
          </option>
        <% end %>
      </select>
    </div>

    <%= render "onboarding/profiles/labeled_input", form: form, field: :max_travel_time_minutes,
               label: "Maximum travel time (minutes)", as: :number_field %>

    <div class="space-y-1">
      <%= form.label :search_status, "Search status", class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :search_status, onboarding_search_statuses, { include_blank: "Select…" },
                      class: "form-input" %>
    </div>

    <%= render "onboarding/profiles/labeled_input", form: form, field: :reason_for_looking, label: "Reason for looking (optional)" %>
  </div>

  <fieldset class="mt-6">
    <legend class="text-sm font-medium text-slate-700">Preferred regions</legend>
    <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-3">
      <% onboarding_regions.each do |region| %>
        <label class="choice-pill">
          <%= check_box_tag "candidate_profile[region_ids][]", region.id,
                            form.object.region_ids.include?(region.id),
                            id: "region_#{region.id}", class: "h-4 w-4 rounded border-slate-300" %>
          <%= region.name %>
        </label>
      <% end %>
    </div>
  </fieldset>

  <fieldset class="mt-6">
    <legend class="text-sm font-medium text-slate-700">Transport type (optional)</legend>
    <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
      <% onboarding_transport_types.each do |transport| %>
        <label class="choice-pill">
          <%= check_box_tag "candidate_profile[transport_type_ids][]", transport.id,
                            form.object.transport_type_ids.include?(transport.id),
                            id: "transport_#{transport.id}", class: "h-4 w-4 rounded border-slate-300" %>
          <%= transport.name %>
        </label>
      <% end %>
    </div>
  </fieldset>
</section>
