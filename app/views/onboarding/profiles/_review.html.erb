<% provenance = CandidateProfiles::FieldProvenance.new(profile) %>

<% if document&.parsing_failed? %>
  <div class="mb-6 flex gap-3 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800" role="alert">
    <svg class="mt-0.5 h-5 w-5 shrink-0 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path><path d="M12 9v4M12 17h.01"></path>
    </svg>
    <span>We couldn't read your CV automatically, so the form below is empty. You can fill it in manually and save as usual.</span>
  </div>
<% elsif document&.parsing_completed? %>
  <div class="mb-6 flex gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-800">
    <svg class="mt-0.5 h-5 w-5 shrink-0 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><path d="M22 4L12 14.01l-3-3"></path>
    </svg>
    <span>We prefilled what we could read from your CV. Please review every field and correct anything before saving. Fields are tagged so you can see what came from your CV.</span>
  </div>
<% end %>

<%= form_with model: profile, url: onboarding_profile_path, method: :patch,
              data: { controller: "conditional-fields" }, class: "space-y-6" do |form| %>
  <% if profile.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4" role="alert">
      <p class="flex items-center gap-2 text-sm font-semibold text-red-800">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle><path d="M12 8v4M12 16h.01"></path>
        </svg>
        <%= pluralize(profile.errors.count, "thing") %> to fix before saving
      </p>
      <ul class="mt-2 list-inside list-disc space-y-1 text-sm text-red-700">
        <% profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render "onboarding/profiles/sections/personal_details", form: form, provenance: provenance %>
  <%= render "onboarding/profiles/sections/job_preferences", form: form, provenance: provenance %>
  <%= render "onboarding/profiles/sections/employment", form: form, provenance: provenance %>
  <%= render "onboarding/profiles/sections/education", form: form %>
  <%= render "onboarding/profiles/sections/work_experience", form: form %>
  <%= render "onboarding/profiles/sections/skills", form: form, profile: profile %>
  <%= render "onboarding/profiles/sections/availability", form: form, provenance: provenance %>
  <%= render "onboarding/profiles/sections/additional_information", form: form %>

  <div class="section-card">
    <label class="flex items-start gap-3 text-sm text-slate-700">
      <%= form.check_box :consent, { checked: profile.consented_at.present?, class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" }, "1", "0" %>
      <span>
        I agree that my CV and profile information may be processed to create and
        improve my candidate profile.
      </span>
    </label>
  </div>

  <div class="sticky bottom-4 z-10 flex items-center justify-between gap-3 rounded-2xl border border-slate-200/70 bg-white/90 px-5 py-3.5 shadow-lg backdrop-blur">
    <p class="hidden text-xs text-slate-500 sm:block">Review everything, then save your profile.</p>
    <%= form.submit "Save profile", class: "btn-primary" %>
  </div>
<% end %>
