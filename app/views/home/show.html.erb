<div class="mx-auto max-w-4xl py-14">
  <div class="text-center">
    <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700 ring-1 ring-inset ring-brand-600/20">
      <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
      Dental recruitment, simplified
    </span>
    <h1 class="mt-5 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      Build your candidate profile in minutes
    </h1>
    <p class="mx-auto mt-3 max-w-xl text-base leading-relaxed text-slate-600">
      Upload your CV and we'll prefill your profile automatically. Review, adjust, and
      submit — no long forms from scratch.
    </p>
  </div>

  <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2">
    <a href="<%= new_onboarding_cv_upload_path %>"
       class="group relative flex flex-col rounded-2xl border border-slate-200/70 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
      <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-600 text-white shadow-sm">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 16V4M7 9l5-5 5 5"></path><path d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2"></path>
        </svg>
      </span>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">I'm a candidate</h2>
      <p class="mt-1.5 flex-1 text-sm leading-relaxed text-slate-600">
        Upload your CV to start. We'll extract your details so you only need to review
        and complete what's missing.
      </p>
      <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700">
        Submit your CV
        <svg class="h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
      </span>
    </a>

    <a href="<%= admin_candidates_path %>"
       class="group relative flex flex-col rounded-2xl border border-slate-200/70 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md">
      <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-slate-800 text-white shadow-sm">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 00-3-3.87"></path><path d="M16 3.13a4 4 0 010 7.75"></path>
        </svg>
      </span>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">I'm a recruiter</h2>
      <p class="mt-1.5 flex-1 text-sm leading-relaxed text-slate-600">
        Browse submitted candidate profiles, review parsed details, and open the
        original CV.
      </p>
      <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-slate-700">
        Go to the admin area
        <svg class="h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
      </span>
    </a>
  </div>

  <div class="mt-14">
    <p class="text-center text-xs font-medium uppercase tracking-wide text-slate-400">How it works</p>
    <ol class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <% [
        ["1", "Upload", "Drop in a PDF, DOC or DOCX. Your CV stays private."],
        ["2", "Review", "We prefill your profile and flag anything to check."],
        ["3", "Submit", "Confirm your details and the team takes it from there."]
      ].each do |number, title, body| %>
        <li class="rounded-xl border border-slate-200/70 bg-white/60 p-4">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-brand-100 text-xs font-semibold text-brand-700"><%= number %></span>
          <h3 class="mt-3 text-sm font-semibold text-slate-900"><%= title %></h3>
          <p class="mt-1 text-sm text-slate-600"><%= body %></p>
        </li>
      <% end %>
    </ol>
  </div>
</div>
