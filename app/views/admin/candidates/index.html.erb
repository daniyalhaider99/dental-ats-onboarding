<div class="py-10">
  <div class="mb-6 flex items-end justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Candidates</h1>
      <p class="mt-1 text-sm text-slate-500"><%= pluralize(@profiles.size, "profile") %> in total</p>
    </div>
  </div>

  <% if @profiles.empty? %>
    <div class="app-card p-10 text-center">
      <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 00-3-3.87"></path></svg>
      </div>
      <p class="text-sm text-slate-500">No candidates yet. Completed profiles will appear here.</p>
    </div>
  <% else %>
    <div class="app-card overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50/80 text-left text-xs font-medium uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Name</th>
            <th class="px-5 py-3">Function</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">CV parsing</th>
            <th class="px-5 py-3">Created</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @profiles.each do |profile| %>
            <tr class="transition hover:bg-brand-50/40">
              <td class="px-5 py-3.5">
                <%= link_to admin_candidate_path(profile), class: "flex items-center gap-3 group" do %>
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-semibold text-brand-700">
                    <%= (profile.full_name || profile.email || "?").strip[0]&.upcase %>
                  </span>
                  <span class="font-medium text-slate-900 group-hover:text-brand-700">
                    <%= profile.full_name || profile.email || "Unnamed draft" %>
                  </span>
                <% end %>
              </td>
              <td class="px-5 py-3.5 text-slate-600"><%= profile.job_function&.name || "—" %></td>
              <td class="px-5 py-3.5">
                <span class="badge <%= profile.completed? ? "bg-emerald-50 text-emerald-700 ring-emerald-600/20" : "bg-slate-100 text-slate-600 ring-slate-500/20" %>">
                  <%= profile.status.humanize %>
                </span>
              </td>
              <td class="px-5 py-3.5 text-slate-600"><%= profile.latest_cv&.parsing_status&.humanize || "—" %></td>
              <td class="px-5 py-3.5 text-slate-500"><%= profile.created_at.to_fs(:short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
