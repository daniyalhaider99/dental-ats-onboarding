<div class="mx-auto max-w-3xl py-10">
  <%= link_to admin_candidates_path, class: "inline-flex items-center gap-1 text-sm text-slate-500 transition hover:text-slate-800" do %>
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
    All candidates
  <% end %>

  <div class="mt-4 flex items-start justify-between gap-4 rounded-2xl border border-slate-200/70 bg-gradient-to-br from-brand-50/70 to-white p-6 shadow-sm">
    <div class="flex items-center gap-4">
      <span class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-600 text-lg font-semibold text-white shadow-sm">
        <%= (@profile.full_name || @profile.email || "?").strip[0]&.upcase %>
      </span>
      <div>
        <h1 class="text-xl font-bold tracking-tight text-slate-900"><%= @profile.full_name || "Unnamed draft" %></h1>
        <p class="text-sm text-slate-500"><%= [ @profile.email, @profile.phone ].compact_blank.join(" · ") %></p>
        <span class="badge mt-1.5 <%= @profile.completed? ? "bg-emerald-50 text-emerald-700 ring-emerald-600/20" : "bg-slate-100 text-slate-600 ring-slate-500/20" %>">
          <%= @profile.status.humanize %>
        </span>
      </div>
    </div>
    <% if @document&.file&.attached? %>
      <%= link_to admin_candidate_cv_path(@profile), class: "btn-secondary shrink-0" do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path><path d="M14 2v6h6"></path></svg>
        View CV
      <% end %>
    <% end %>
  </div>

  <dl class="mt-6 grid grid-cols-1 gap-x-6 gap-y-3 rounded-2xl border border-slate-200/70 bg-white p-6 text-sm shadow-sm sm:grid-cols-2">
    <% {
      "City" => @profile.city, "Country" => @profile.country,
      "Function" => @profile.job_function&.name, "Search status" => @profile.search_status&.humanize,
      "Years of experience" => @profile.years_of_experience, "Available from" => @profile.available_from,
      "BIG status" => @profile.big_registration_status&.humanize, "BIG number" => @profile.big_number,
      "Regions" => @profile.regions.map(&:name).join(", ").presence,
      "Employment types" => @profile.employment_types.map(&:name).join(", ").presence,
      "Working days" => @profile.working_days.map(&:name).join(", ").presence,
      "Languages" => @profile.languages.map(&:name).join(", ").presence
    }.each do |label, value| %>
      <div>
        <dt class="text-xs uppercase tracking-wide text-slate-400"><%= label %></dt>
        <dd class="text-slate-800"><%= value.presence || "—" %></dd>
      </div>
    <% end %>
  </dl>

  <% if @profile.professional_summary.present? %>
    <div class="mt-6 rounded-2xl border border-slate-200/70 bg-white p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-slate-900">Professional summary</h2>
      <p class="mt-2 text-sm text-slate-700"><%= @profile.professional_summary %></p>
    </div>
  <% end %>

  <%= render "admin/candidates/collection", title: "Education",
             records: @profile.educations, formatter: ->(e) { "#{e.study} — #{e.institution}".chomp(" — ") } %>
  <%= render "admin/candidates/collection", title: "Work experience",
             records: @profile.work_experiences, formatter: ->(w) { "#{w.job_title} — #{w.company_name}" } %>

  <div class="mt-6 rounded-2xl border border-slate-200/70 bg-white p-6 shadow-sm">
    <h2 class="text-sm font-semibold text-slate-900">Skills</h2>
    <div class="mt-2 flex flex-wrap gap-2">
      <% @profile.skills.each do |skill| %>
        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-700"><%= skill.name %></span>
      <% end %>
      <% @profile.candidate_skills.suggested.each do |cs| %>
        <span class="rounded-full bg-amber-50 px-2.5 py-0.5 text-xs text-amber-700" title="Suggested from CV">
          <%= cs.free_text_suggestion %> (review)
        </span>
      <% end %>
    </div>
  </div>
</div>
